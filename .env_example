# Leia o README.md para instruções de instalação e configuração

# Usado pelo Netdata e para identificação   
NODE_NAME="site-b-rasp" 

# Seu domínio gerenciado pela Cloudflare   
DOMAIN=example.net

# Vai gerar: traefik.site-b.example.net   
SUBDOMAIN="site-b"      

# ==========================================
# SEGURANÇA E TÚNEIS
# ==========================================

# Tunnel Token criado na CloudFlare
CF_TUNNEL_TOKEN="AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"

# hash de senha criado localmente para acessar o dashboard
BASIC_AUTH="user:$$apr1$$/NNNNNNNNNNNNNNNNNNNNNNNNNNNNNNN"

# necessário que o container crowdsec esteja em execução para gerar o token do bouncer
# comando para gerar o token:
# docker exec -t crowdsec cscli bouncers add traefik-bouncer
TOKEN_BOUNCER="AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
